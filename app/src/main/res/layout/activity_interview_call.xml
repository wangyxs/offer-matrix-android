<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <!-- 面试官头像区域 -->
    <View
        android:id="@+id/avatarBackground"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/bg_avatar_circle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35" />

    <!-- 面试官图标 -->
    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_interviewer"
        android:contentDescription="面试官"
        app:layout_constraintBottom_toBottomOf="@id/avatarBackground"
        app:layout_constraintEnd_toEndOf="@id/avatarBackground"
        app:layout_constraintStart_toStartOf="@id/avatarBackground"
        app:layout_constraintTop_toTopOf="@id/avatarBackground" />

    <!-- 状态指示器 (语音波动动画) -->
    <View
        android:id="@+id/voiceIndicator"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:alpha="0.3"
        android:background="@drawable/bg_voice_wave"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/avatarBackground"
        app:layout_constraintEnd_toEndOf="@id/avatarBackground"
        app:layout_constraintStart_toStartOf="@id/avatarBackground"
        app:layout_constraintTop_toTopOf="@id/avatarBackground" />

    <!-- 通话状态文字 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="正在连接..."
        android:textColor="#00d9ff"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/avatarBackground" />

    <!-- 通话时长 -->
    <TextView
        android:id="@+id/tvDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="00:00"
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus" />

    <!-- 隐藏的文本显示 (用于后台记录，不显示) -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAiText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvUserText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- 挂断按钮 -->
    <ImageButton
        android:id="@+id/btnHangup"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/bg_hangup_button"
        android:contentDescription="挂断"
        android:src="@drawable/ic_call_end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
